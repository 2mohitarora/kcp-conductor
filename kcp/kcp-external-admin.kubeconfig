apiVersion: v1
clusters:
- cluster:
    insecure-skip-tls-verify: true
    server: https://kcp.example.com:443/clusters/root
  name: external-logical-cluster-admin
contexts:
- context:
    cluster: external-logical-cluster-admin
    user: external-logical-cluster-admin
  name: external-logical-cluster
kind: Config
users:
- name: external-logical-cluster-admin
  user:
    client-certificate: /tmp/kcp-client.crt
    client-key: /tmp/kcp-client.key
