apiVersion: v1
kind: Config
current-context: workflow-user
clusters:
- cluster:
    insecure-skip-tls-verify: true
    server: https://kcp.example.com:443/clusters/root:workflow-user
  name: workflow-user
contexts:
- context:
    cluster: workflow-user
    user: wf-user
  name: workflow-user
users:
- name: wf-user
  user:
    token: wf-user-token