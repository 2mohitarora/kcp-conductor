apiVersion: v1
kind: Config
current-context: workflow-admin
clusters:
- cluster:
    insecure-skip-tls-verify: true
    server: https://kcp:6443/clusters/root:workflow-admin
  name: workflow-admin
contexts:
- context:
    cluster: workflow-admin
    user: wf-admin
  name: workflow-admin
users:
- name: wf-admin
  user:
    token: wf-admin-token