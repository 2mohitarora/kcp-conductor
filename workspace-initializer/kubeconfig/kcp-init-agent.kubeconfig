apiVersion: v1
clusters:
- cluster:
    insecure-skip-tls-verify: true
    server: https://kcp.example.com:443/clusters/root:init-agent
  name: external-admin
contexts:
- context:
    cluster: external-admin
    user: external-admin
  name: external-admin
current-context: external-admin
kind: Config
users:
- name: external-admin
  user:
    token: admin-token
